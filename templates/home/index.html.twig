{% extends 'base.html.twig' %}

{% block title %}
	Accueil - GameStore
{% endblock %}

{% block body %}
	<section class="py-5 text-center container bg-secondary ">
		<div class="row py-lg-5">
			<div class="col-lg-6 col-md-8 mx-auto ">
				<h1 class="fw-light text-info">Bienvenue sur GameStore</h1>
				<p class="lead text-muted">Découvrez notre catalogue de jeux vidéo. Les meilleurs titres au meilleur prix, pour toutes les consoles !</p>
			</div>
		</div>
	</section>

	<div class="album py-5 bg-light">
		<div class="container">
			<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
				{% for produit in produits %}
					<div class="col">
						<div class="card shadow-sm h-100">
							{% if produit.image %}
								<img src="{{ produit.image }}" class="bd-placeholder-img card-img-top" width="100%" height="225" alt="{{ produit.nom }}" style="object-fit: cover;">
							{% else %}
								<svg class="bd-placeholder-img card-img-top" width="100%" height="225" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Placeholder: Thumbnail" preserveaspectratio="xMidYMid slice" focusable="false">
									<title>Placeholder</title><rect width="100%" height="100%" fill="#55595c"/><text x="50%" y="50%" fill="#eceeef" dy=".3em">No Image</text>
								</svg>
							{% endif %}

							<div class="card-body d-flex flex-column">
								<h5 class="card-title">{{ produit.nom }}</h5>
								<p class="card-text flex-grow-1">{{ produit.description|slice(0, 100) ~ '...' }}</p>
								<div class="d-flex justify-content-between align-items-center mt-3">
									<div class="btn-group">
										<a href="{{ path('cart_add', {'id': produit.id}) }}" class="btn btn-sm btn-primary">Ajouter au panier</a>
									</div>
									<span class="text-success fw-bold fs-5">{{ produit.prix }}
										€</span>
								</div>
							</div>
						</div>
					</div>
				{% else %}
					<div class="col-12 text-center">
						<p>Aucun jeu n'est disponible pour le moment.</p>
					</div>
				{% endfor %}
			</div>
		</div>
	</div>
{% endblock %}