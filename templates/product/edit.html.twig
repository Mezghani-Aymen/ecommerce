{% extends 'base.html.twig' %}

{% block title %}Modifier un produit
{% endblock %}

{% block body %}
	<div class="row">
		<div class="col-md-8 offset-md-2">
			<h1 class="mb-4">Modifier le jeu :
				{{ produit.nom }}</h1>

			<div class="card shadow-sm">
				<div class="card-body">
					{{ form_start(form) }}
					{{ form_widget(form) }}
					<div class="mt-4 d-flex justify-content-between">
						<a href="{{ path('admin_product_index') }}" class="btn btn-secondary">Retour à la liste</a>
						<button class="btn btn-primary">{{ button_label|default('Mettre à jour') }}</button>
					</div>
					{{ form_end(form) }}
				</div>
			</div>
		</div>
	</div>
{% endblock %}
