{% extends 'base.html.twig' %}

{% block title %}Inscription{% endblock %}

{% block body %}
    <div class="row">
        <div class="col-md-6 offset-md-3">
            <h1 class="h3 mb-3 font-weight-normal text-center">Inscription</h1>

            <div class="card shadow-sm">
                <div class="card-body">
                    {{ form_start(registrationForm) }}
                        <div class="mb-3">
                            {{ form_label(registrationForm.email) }}
                            {{ form_widget(registrationForm.email) }}
                            {{ form_errors(registrationForm.email) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(registrationForm.pseudo) }}
                            {{ form_widget(registrationForm.pseudo) }}
                            {{ form_errors(registrationForm.pseudo) }}
                        </div>
                        <div class="mb-3">
                            {{ form_label(registrationForm.plainPassword) }}
                            {{ form_widget(registrationForm.plainPassword) }}
                            {{ form_errors(registrationForm.plainPassword) }}
                        </div>

                        <button type="submit" class="btn btn-lg btn-primary w-100 mt-2">S'inscrire</button>
                    {{ form_end(registrationForm) }}
                    
                    <hr>
                    <div class="text-center">
                        <p class="mb-0">
                            Déjà un compte ?
                            <a href="{{ path('app_login') }}">Se connecter</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
