<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}GameStore
			{% endblock %}
		</title>

		<!-- Bootstrap CSS -->
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

		{% block stylesheets %}
			<style>
				body {
					background-color: #f8f9fa;
				}
				.navbar {
					background-color: #343a40;
				}
				.navbar-brand,
				.nav-link {
					color: #fff !important;
				}
				.nav-link:hover {
					color: #0dcaf0 !important;
				}
			</style>
		{% endblock %}
	</head>
	<body class="d-flex flex-column min-vh-100">
		<nav class="navbar navbar-expand-lg navbar-dark shadow-sm">
			<div class="container">
				<a class="navbar-brand fw-bold " href="{{ path('home') }} ">
					<i class="bi bi-controller  "></i>
					GameStore</a>
				<button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
					<span class="navbar-toggler-icon"></span>
				</button>
				<div class="collapse navbar-collapse" id="navbarNav">
					<ul class="navbar-nav me-auto">
						<li class="nav-item">
							<a class="nav-link" href="{{ path('home') }}">Accueil</a>
						</li>
					</ul>
					<ul class="navbar-nav ms-auto">
						<li class="nav-item">
							<a class="nav-link" href="{{ path('cart_index') }}">
								<i class="bi bi-cart3"></i>
								Panier
								{% set cart = app.session.get('cart', []) %}
								{% if cart|length > 0 %}
									<span class="badge bg-danger rounded-pill">{{ cart|length }}</span>
								{% endif %}
							</a>
						</li>

						{% if app.user %}
							{# Check Authentication ==> app.user = null (anonymous) Else User (admin)  #}
							{% if is_granted('ROLE_ADMIN') %}
								<li class="nav-item">
									<a class="nav-link" href="{{ path('admin_product_index') }}">Espace Admin</a>
								</li>
							{% endif %}
							<li class="nav-item">
								<a class="nav-link btn btn-outline-danger ms-2 btn-sm mt-1" href="{{ path('app_logout') }}">Déconnexion</a>
							</li>
						{% else %}
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_login') }}">Connexion</a>
							</li>
							<li class="nav-item">
								<a class="nav-link" href="{{ path('app_register') }}">S'inscrire</a>
							</li>
						{% endif %}
					</ul>
				</div>
			</div>
		</nav>

		<main class="container my-5  "> {% block body %}{% endblock %}
			</main>

			<footer class="text-muted py-5 bg-dark text-white mt-auto">
				<div class="container">
					<p class="float-end mb-1">
						<a href="#" class="text-white">Retour en haut</a>
					</p>
					<p class="mb-1">Mini-projet Symfony - Thème Jeux Vidéo &copy;
						{{ "now"|date("Y") }}</p>
				</div>
			</footer>

			<!-- Bootstrap JS -->
			<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
			{% block javascripts %}{% endblock %}
		</body>
	</html>